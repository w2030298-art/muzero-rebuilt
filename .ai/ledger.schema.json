{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "wkstruc-ledger/v9",
  "type": "object",
  "required": ["schema_version", "task_id", "state", "progress", "last_run", "validation", "open_items", "checkpoint_id"],
  "properties": {
    "schema_version": {"type": "string", "const": "wkstruc-ledger/v9"},
    "task_id": {"type": "string"},
    "state": {"type": "string", "enum": ["PENDING", "IN_PROGRESS", "BLOCKED", "DONE"]},
    "progress": {
      "type": "object",
      "required": ["done", "total", "label"],
      "properties": {
        "done": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0},
        "label": {"type": "string"}
      }
    },
    "last_run": {
      "type": "object",
      "required": ["at", "agent", "summary"],
      "properties": {
        "at": {"type": ["string", "null"]},
        "agent": {"type": "string"},
        "summary": {"type": "string"}
      }
    },
    "validation": {
      "type": "object",
      "required": ["status", "commands", "summary"],
      "properties": {
        "status": {"type": "string", "enum": ["NOT_RUN", "PASS", "FAIL"]},
        "commands": {"type": "array", "items": {"type": "string"}},
        "summary": {"type": "string"}
      }
    },
    "open_items": {"type": "array", "items": {"type": "string"}},
    "checkpoint_id": {"type": "string"},
    "last_review_report": {"type": ["string", "null"]},
    "consumed_inbox": {"type": "array", "items": {"type": "string"}}
  }
}
